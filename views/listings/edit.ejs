<%- layout("/layouts/boilerplate") -%>
    <div class="row">
        <div class="col-8 offset-2">
            <br>
            <h3>Edit your listing</h3>
            <form method="post" action="/listings/<%=listing._id%>?_method=PUT">

                <div>
                    <label for="title" class="form-label"></label>
                    <input class="form-control" type="text" name="listing[title]" value="<%=listing.title%>"">
        </div>
       
        <div>
             <label for=" description" class="form-label"></label>
                    <textarea class="form-control" type="text"
                        name="listing[description]"><%=listing.description%></textarea>
                </div>

                <div>
                    <label for="image" class="form-label"></label>
                    <input class="form-control" type="text" name="listing[image]" value="<%=listing.image.url%>">
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <label for="price" class="form-label "></label>
                        <input class="form-control" type="number" name="listing[price]" value="<%=listing.price%>">
                    </div>

                    <div class="col-md-8">
                        <label for="location" class="form-label"></label>
                        <input class="form-control" type="text" name="listing[location]" value="<%=listing.location%>">
                    </div>
                </div>


                <div>
                    <label for="country" class="form-label"></label>
                    <input class="form-control" type="text" name="listing[country]" , value="<%=listing.country%>">
                </div>

                <br>

                <button class="btn btn-dark add-btn">Edit</button>
            </form>
        </div>
    </div>