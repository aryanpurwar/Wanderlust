<%- layout("/layouts/boilerplate") -%>
    <div class="row">
        <div class="col-8 offset-2">
            <br>
            <h3>Create a new listing</h3>
            <form method="post" action="/listings" novalidate class="needs-validation">

                <div class="mb-3">
                    <label for="title" class="form-label"></label>
                    <input required type="text" name="listing[title]" class="form-control" placeholder="Enter title" >
                    <div class="valid-feedback">Looks Good!</div>
                    
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label"></label>
                    <textarea  required type="text" name="listing[description]" class="form-control"
                        placeholder="Enter description"></textarea>
                    <div class="invalid-feedback">please enter valid description</div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label"></label>
                    <input type="text" name="listing[image]" class="form-control" placeholder="Enter image url/link">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label"></label>
                        <input required name="listing[price]" placeholder="Enter price" class="form-control">
                        <div class="invalid-feedback">please enter valid price</div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label"></label>
                        <input required type="text" name="listing[location]" placeholder="Enter location" class="form-control">
                        <div class="invalid-feedback">please enter valid loacation</div>
                    </div>
                </div>


                <div class="mb-3">
                    <label for="country" class="form-label"></label>
                    <input required type="text" name="listing[country]" , placeholder="Enter country" class="form-control">
                    <div class="invalid-feedback">please enter valid country</div>
                </div>
                <br>
                <button class="btn btn-dark mb-3 add-btn">Add</button>
            </form>
        </div>
    </div>